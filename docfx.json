{
  "$schema": "https://raw.githubusercontent.com/dotnet/docfx/main/schemas/docfx.schema.json",
  "metadata": [
    {
      "src": [
        {
          "src": ".",
          "files": [
            "UrlShortener.Api/UrlShortener.Api.csproj",
            "UrlShortener.Application/UrlShortener.Application.csproj",
            "UrlShortener.Domain/UrlShortener.Domain.csproj",
            "UrlShortener.Infrastructure/UrlShortener.Infrastructure.csproj",
            "UrlShortener.Messaging.Contracts/UrlShortener.Messaging.Contracts.csproj",
            "UrlShortener.AnalyticsService/UrlShortener.AnalyticsService.csproj",
            "UrlShortener.NotificationsService/UrlShortener.NotificationsService.csproj"
          ],
          "exclude": [
            "**/bin/**",
            "**/obj/**"
          ]
        }
      ],
      "dest": "api"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "docs/**.md",
          "docs/**/toc.yml",
          "toc.yml",
          "*.md"
        ],
        "exclude": [
          "_site/**"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appName": "UrlShortener",
      "_appTitle": "UrlShortener",
      "_enableSearch": true
    }
  }
}